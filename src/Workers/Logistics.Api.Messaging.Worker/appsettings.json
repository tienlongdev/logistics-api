{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=logistics_db;Username=logistics_user;Password=logistics_pass;",
    "Elasticsearch": "http://localhost:9200",
    "RabbitMQ": "amqp://logistics_user:logistics_pass@localhost:5672/logistics_vhost"
  },
  "Messaging": {
    "OutboxPublisher": {
      "PollIntervalSeconds": 5,
      "BatchSize": 50,
      "MaxRetryCount": 10,
      "BaseRetryDelaySeconds": 5,
      "MaxRetryDelaySeconds": 300
    }
  },
  "Search": {
    "Shipments": {
      "IndexName": "logistics-shipments-v1",
      "EnsureIndexOnStartup": true,
      "BackfillOnStartup": true,
      "BackfillBatchSize": 500
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}